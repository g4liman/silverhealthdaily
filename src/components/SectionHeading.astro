---
interface Props {
  label?: string;
  title: string;
  description?: string;
  centered?: boolean;
}

const { label, title, description, centered = false } = Astro.props;
const align = centered ? 'text-center mx-auto' : '';
---

<div class={`mb-10 max-w-2xl ${align}`}>
  {label && <p class="section-label">{label}</p>}
  <h2 class="section-title">{title}</h2>
  {description && <p class="mt-3 text-lg text-muted">{description}</p>}
</div>
