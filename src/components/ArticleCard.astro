---
import type { CollectionEntry } from 'astro:content';
import { getCategory } from '../lib/site';

interface Props {
  article: CollectionEntry<'articles'>;
  featured?: boolean;
}

const { article, featured = false } = Astro.props;
const category = getCategory(article.data.category);
const date = article.data.publishDate.toLocaleDateString('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
});
---

<article
  class:list={[
    'group card-lift overflow-hidden rounded-2xl bg-white shadow-md ring-1 ring-sage-100',
    featured && 'md:col-span-1',
  ]}
>
  <a href={`/articles/${article.id}`} class="block">
    <div
      class:list={[
        'relative flex h-36 items-end overflow-hidden bg-gradient-to-br p-5',
        category?.gradient ?? 'from-sage-600 to-sage-800',
      ]}
    >
      <div
        class="pointer-events-none absolute inset-0 opacity-20"
        style="background-image: radial-gradient(circle at 20% 80%, white 1px, transparent 1px); background-size: 24px 24px;"
      />
      <span class="relative text-4xl drop-shadow-sm" aria-hidden="true">{category?.icon ?? '📖'}</span>
      {
        featured && (
          <span class="absolute right-4 top-4 rounded-full bg-white/20 px-3 py-1 text-xs font-bold uppercase tracking-wide text-white backdrop-blur">
            Featured
          </span>
        )
      }
    </div>

    <div class="p-6">
      <div class="mb-3 flex flex-wrap items-center gap-2">
        {
          category && (
            <span
              class:list={[
                'rounded-full px-2.5 py-0.5 text-xs font-semibold ring-1',
                category.tint,
              ]}
            >
              {category.name}
            </span>
          )
        }
        <span class="text-xs font-medium text-muted">{article.data.readTime} min read</span>
      </div>
      <h2 class="font-display mb-2 text-xl font-bold leading-snug text-ink group-hover:text-sage-700">
        {article.data.title}
      </h2>
      <p class="mb-4 line-clamp-2 text-sm leading-relaxed text-muted">
        {article.data.description}
      </p>
      <time datetime={article.data.publishDate.toISOString()} class="text-xs font-medium text-sage-600">
        {date}
      </time>
    </div>
  </a>
</article>
