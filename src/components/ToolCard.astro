---
import OptimizedImage from './OptimizedImage.astro';

interface Props {
  title: string;
  description: string;
  href: string;
  image: string;
  imageAlt: string;
}

const { title, description, href, image, imageAlt } = Astro.props;
---

<a
  href={href}
  class="group card-lift flex h-full flex-col overflow-hidden rounded-2xl bg-white shadow-md ring-1 ring-sage-100"
>
  <div class="relative aspect-[16/10] overflow-hidden bg-sage-100">
    <OptimizedImage
      src={image}
      alt={imageAlt}
      width={480}
      height={300}
      class="tool-card-img h-full w-full object-cover"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-sage-900/50 to-transparent" />
  </div>
  <div class="flex flex-1 flex-col p-6">
    <h2 class="font-display text-lg font-bold text-ink group-hover:text-sage-700">{title}</h2>
    <p class="mt-2 flex-1 text-sm leading-relaxed text-muted">{description}</p>
    <span class="mt-4 text-sm font-semibold text-sage-700">Open tool →</span>
  </div>
</a>
