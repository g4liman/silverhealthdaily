<div
  id="cookie-banner"
  class="fixed inset-x-0 bottom-0 z-[100] hidden border-t border-sage-200 bg-white/95 p-4 shadow-2xl backdrop-blur-md"
  role="dialog"
  aria-label="Cookie consent"
>
  <div class="mx-auto flex max-w-6xl flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <p class="text-sm text-ink-soft">
      We use cookies for analytics and ads. See our
      <a href="/privacy" class="font-semibold text-sage-700 underline">Privacy Policy</a>.
    </p>
    <div class="flex shrink-0 gap-3">
      <button
        id="cookie-decline"
        type="button"
        class="rounded-full border border-sage-200 px-5 py-2 text-sm font-semibold text-ink-soft transition hover:bg-sage-50"
      >
        Decline
      </button>
      <button
        id="cookie-accept"
        type="button"
        class="rounded-full bg-sage-700 px-5 py-2 text-sm font-semibold text-white transition hover:bg-sage-800"
      >
        Accept
      </button>
    </div>
  </div>
</div>

<script>
  const KEY = 'shd_cookie_consent';
  const banner = document.getElementById('cookie-banner');
  const accept = document.getElementById('cookie-accept');
  const decline = document.getElementById('cookie-decline');

  if (banner && !localStorage.getItem(KEY)) {
    banner.classList.remove('hidden');
  }

  function closeBanner(value: string) {
    localStorage.setItem(KEY, value);
    banner?.classList.add('hidden');
    if (value === 'accepted') {
      window.dispatchEvent(new Event('shd:consent-accepted'));
    }
  }

  accept?.addEventListener('click', () => closeBanner('accepted'));
  decline?.addEventListener('click', () => closeBanner('declined'));
</script>
