---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('articles')).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);
---

<BaseLayout
  title="Health Articles for Adults 50+"
  description="Browse nutrition, fitness, sleep, and heart health guides written for adults 50 and older."
>
  <section class="border-b border-sage-100 bg-gradient-to-b from-sage-50 to-cream py-14">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <SectionHeading
        label="Library"
        title="All health guides"
        description="Evidence-informed articles updated regularly. Always discuss changes with your healthcare provider."
      />
    </div>
  </section>

  <div class="mx-auto max-w-6xl px-4 py-14 sm:px-6">
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {articles.map((article) => <ArticleCard article={article} />)}
    </div>
  </div>
</BaseLayout>
