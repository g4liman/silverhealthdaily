---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import PageHero from '../../components/PageHero.astro';
import ScrollReveal from '../../components/ScrollReveal.astro';
import { getCollection } from 'astro:content';
import { PAGE_HEROES } from '../../lib/media';

const articles = (await getCollection('articles')).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);
---

<BaseLayout
  title="Health Articles & Guides"
  description="Browse nutrition, fitness, sleep, and heart health guides — clear advice for everyday wellness."
>
  <PageHero
    image={PAGE_HEROES.articles}
    label="Library"
    title="All health guides"
    description="Evidence-informed articles updated regularly. Always discuss changes with your healthcare provider."
  />

  <div class="mx-auto max-w-6xl px-4 py-14 sm:px-6">
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {articles.map((article, i) => (
        <ScrollReveal delay={i * 50}>
          <ArticleCard article={article} />
        </ScrollReveal>
      ))}
    </div>
  </div>
</BaseLayout>
