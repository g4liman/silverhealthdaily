---
import BaseLayout from '../layouts/BaseLayout.astro';
import AdSlot from '../components/AdSlot.astro';
import ArticleCard from '../components/ArticleCard.astro';
import ToolCard from '../components/ToolCard.astro';
import HeroIllustration from '../components/HeroIllustration.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { getCollection } from 'astro:content';
import { SITE, CATEGORIES, TRUST_POINTS } from '../lib/site';

const articles = (await getCollection('articles'))
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
const featured = articles.filter((a) => a.data.featured).slice(0, 3);
const latest = articles.slice(0, 6);
const articleCount = articles.length;
---

<BaseLayout>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-sage-50 via-cream to-cream-dark"></div>
    <div
      class="absolute -right-32 -top-32 h-96 w-96 rounded-full bg-gold/10 blur-3xl"
      aria-hidden="true"
    ></div>
    <div
      class="absolute -bottom-20 -left-20 h-72 w-72 rounded-full bg-sage-200/40 blur-3xl"
      aria-hidden="true"
    ></div>

    <div class="relative mx-auto grid max-w-6xl items-center gap-10 px-4 py-16 sm:px-6 lg:grid-cols-2 lg:py-24">
      <div>
        <p class="section-label">
          <span class="inline-block h-1.5 w-1.5 rounded-full bg-gold"></span>
          Health for adults 50+
        </p>
        <h1 class="font-display text-4xl font-bold leading-[1.15] tracking-tight text-ink sm:text-5xl lg:text-[3.25rem]">
          Your best years deserve
          <span class="gradient-text"> better health advice</span>
        </h1>
        <p class="mt-6 max-w-lg text-lg leading-relaxed text-muted">
          Clear guides on nutrition, movement, sleep, and heart health — plus free tools. No jargon,
          no fear-mongering. Just practical wisdom for living well.
        </p>
        <div class="mt-8 flex flex-wrap gap-4">
          <a href="/articles" class="btn-primary">
            Browse {articleCount} guides
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a href="/tools" class="btn-secondary">Free calculators</a>
        </div>
      </div>

      <div class="relative mx-auto w-full max-w-md lg:max-w-none">
        <div class="overflow-hidden rounded-3xl shadow-2xl shadow-sage-900/10 ring-1 ring-sage-200/60">
          <HeroIllustration />
        </div>
        <div
          class="absolute -bottom-4 -left-4 rounded-2xl bg-white px-5 py-4 shadow-xl ring-1 ring-sage-100"
        >
          <p class="font-display text-2xl font-bold text-sage-800">50+</p>
          <p class="text-xs font-medium text-muted">Written for you</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust bar -->
  <section class="border-y border-sage-100 bg-white/60 backdrop-blur-sm">
    <div class="mx-auto flex max-w-6xl flex-wrap items-center justify-center gap-x-10 gap-y-3 px-4 py-5 sm:px-6">
      {
        TRUST_POINTS.map((point) => (
          <span class="flex items-center gap-2 text-sm font-medium text-ink-soft">
            <svg class="h-4 w-4 text-sage-600" fill="currentColor" viewBox="0 0 20 20">
              <path
                fill-rule="evenodd"
                d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                clip-rule="evenodd"
              />
            </svg>
            {point}
          </span>
        ))
      }
    </div>
  </section>

  <AdSlot slot="3333333333" format="horizontal" class="mx-auto max-w-6xl px-4 pt-10" />

  <!-- Categories -->
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:py-20">
    <SectionHeading
      label="Explore topics"
      title="What would you like to feel better about?"
      description="Pick a topic and find guides written in plain English, with steps you can take today."
    />
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        CATEGORIES.map((cat) => (
          <a
            href={`/category/${cat.slug}`}
            class="group card-lift flex gap-4 rounded-2xl bg-white p-6 shadow-md ring-1 ring-sage-100"
          >
            <span
              class:list={[
                'flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-gradient-to-br text-2xl shadow-sm',
                cat.gradient,
              ]}
            >
              {cat.icon}
            </span>
            <div>
              <h3 class="font-display text-lg font-bold text-ink group-hover:text-sage-700">
                {cat.name}
              </h3>
              <p class="mt-1 text-sm leading-relaxed text-muted">{cat.description}</p>
            </div>
          </a>
        ))
      }
    </div>
  </section>

  <!-- Featured -->
  {
    featured.length > 0 && (
      <section class="bg-sage-900 py-16 lg:py-20">
        <div class="mx-auto max-w-6xl px-4 sm:px-6">
          <div class="mb-10 max-w-2xl">
            <p class="section-label !text-gold-light">Editor's picks</p>
            <h2 class="font-display text-3xl font-bold text-white sm:text-4xl">
              Start with these guides
            </h2>
            <p class="mt-3 text-lg text-sage-200">
              Our most helpful reads for staying active, eating well, and protecting your heart.
            </p>
          </div>
          <div class="grid gap-6 md:grid-cols-3">
            {featured.map((article) => (
              <ArticleCard article={article} featured />
            ))}
          </div>
        </div>
      </section>
    )
  }

  <!-- Latest -->
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:py-20">
    <div class="mb-10 flex flex-wrap items-end justify-between gap-4">
      <SectionHeading label="Fresh reads" title="Latest articles" />
      <a
        href="/articles"
        class="inline-flex items-center gap-1 text-sm font-semibold text-sage-700 hover:text-sage-900"
      >
        View all {articleCount} articles
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {latest.map((article) => <ArticleCard article={article} />)}
    </div>
  </section>

  <!-- Tools -->
  <section class="border-t border-sage-100 bg-gradient-to-b from-cream-dark to-cream py-16 lg:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <SectionHeading
        label="Free tools"
        title="Quick answers, no signup"
        description="Handy calculators for the questions you Google at 2am — BMI, hydration, and walking calories."
        centered
      />
      <div class="grid gap-5 md:grid-cols-3">
        <ToolCard
          title="BMI Calculator"
          description="Check your body mass index with context that makes sense after 50."
          href="/tools/bmi-calculator"
          icon="⚖️"
          accent="from-emerald-600 to-teal-700"
        />
        <ToolCard
          title="Water Intake"
          description="Estimate how much water your body needs based on weight and activity."
          href="/tools/water-intake-calculator"
          icon="💧"
          accent="from-sky-600 to-blue-700"
        />
        <ToolCard
          title="Walking Calories"
          description="See how much your daily walk is doing for your health."
          href="/tools/walking-calorie-calculator"
          icon="🚶"
          accent="from-amber-500 to-orange-600"
        />
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
    <div
      class="relative overflow-hidden rounded-3xl bg-gradient-to-br from-sage-700 via-sage-800 to-sage-900 px-8 py-12 text-center shadow-2xl sm:px-16 sm:py-16"
    >
      <div
        class="pointer-events-none absolute inset-0 opacity-10"
        style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 32px 32px;"
        aria-hidden="true"
      ></div>
      <p class="relative section-label !text-gold-light">Stay informed</p>
      <h2 class="relative font-display mx-auto max-w-xl text-3xl font-bold text-white sm:text-4xl">
        Health is a daily habit — we're here every step
      </h2>
      <p class="relative mx-auto mt-4 max-w-lg text-sage-200">
        Bookmark {SITE.name} and check back for new guides. Your future self will thank you.
      </p>
      <a href="/articles" class="relative btn-primary mt-8 !bg-white !text-sage-800 !shadow-none hover:!bg-cream">
        Explore all articles
      </a>
    </div>
  </section>
</BaseLayout>
