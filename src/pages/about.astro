---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import { SITE } from '../lib/site';
import { PAGE_HEROES } from '../lib/media';
---

<BaseLayout
  title="About"
  description="Learn about Silver Health Daily — practical health guides and free tools for everyday wellness."
>
  <PageHero
    image={PAGE_HEROES.about}
    label="Our mission"
    title={`About ${SITE.name}`}
    description="Practical health information for everyone — clear, readable, and free."
  />

  <div class="prose mx-auto max-w-3xl px-4 py-12 sm:px-6">
    <p>
      {SITE.name} publishes practical health information for everyday wellness. Our goal is
      clear, readable content on nutrition, movement, sleep, and everyday wellness — without
      hype or fear-mongering.
    </p>
    <p>
      We are not a medical practice. Articles are researched and written for general education.
      Always work with your doctor before changing diet, exercise, or medications.
    </p>
    <h2>What we publish</h2>
    <ul>
      <li>Short, actionable health guides optimized for busy readers</li>
      <li>Free calculators (BMI, hydration, walking calories)</li>
      <li>Topic hubs on heart health, brain health, fitness, and more</li>
    </ul>
    <h2>Contact</h2>
    <p>
      Questions or corrections? Email us at{' '}
      <a href={`mailto:${SITE.email}`}>{SITE.email}</a>.
    </p>
  </div>
</BaseLayout>
