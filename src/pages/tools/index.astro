---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolCard from '../../components/ToolCard.astro';
import PageHero from '../../components/PageHero.astro';
import { TOOL_IMAGES, PAGE_HEROES } from '../../lib/media';
---

<BaseLayout
  title="Free Health Tools"
  description="Free BMI, water intake, and walking calorie calculators for everyday health."
>
  <PageHero
    image={PAGE_HEROES.tools}
    label="Calculators"
    title="Free health tools"
    description="Simple calculators to support everyday wellness. Results are estimates — not medical advice."
  />

  <div class="mx-auto max-w-6xl px-4 py-14 sm:px-6">
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      <ToolCard
        title="BMI Calculator"
        description="Calculate body mass index with plain-language results."
        href="/tools/bmi-calculator"
        image={TOOL_IMAGES.bmi.src}
        imageAlt={TOOL_IMAGES.bmi.alt}
      />
      <ToolCard
        title="Water Intake Calculator"
        description="Estimate how much water to drink daily."
        href="/tools/water-intake-calculator"
        image={TOOL_IMAGES.water.src}
        imageAlt={TOOL_IMAGES.water.alt}
      />
      <ToolCard
        title="Walking Calorie Calculator"
        description="Estimate calories burned while walking."
        href="/tools/walking-calorie-calculator"
        image={TOOL_IMAGES.walking.src}
        imageAlt={TOOL_IMAGES.walking.alt}
      />
    </div>
  </div>
</BaseLayout>
